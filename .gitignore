# OS / editor
.DS_Store
Thumbs.db

# Eclipse / workspace metadata
.metadata/
.settings/
.classpath
.project

# Legacy VCS metadata
.svn/

# Build outputs
target/
build/
build_tmp*/
dist/

# Frontend project — created per-project via bootstrap-frontend, never committed
src/main/frontend/

# React build output — created per-project via npm run build + copy, never committed
src/main/webapp/ui/

# Source analysis output — generated per-project by SourceAnalyzer
source-analysis/

# Runtime logs / diagnostics
*.log
gcm-diagnose.log

# QA captures (generated per-project)
captures/

# Automation run logs (generated per-project)
automation/logs/

# Large vendor archive (GitHub 100MB limit)
src/main/webapp/resources/component/Highcharts/api.zip

# Project-specific docs (generated per-project, not reusable templates)
docs/project-docs/docs-migration-inventory.md
docs/project-docs/docs-main-*.md

